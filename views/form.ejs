<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Job Application Form</title>
    <link rel="stylesheet" href="/css/style.css">
</head>

<body>

    <div id="title">
        <h3>Job Application Form</h3>
    </div>

    <form METHOD="POST" action="/form/add" id="jobapplication-form">

        <fieldset id="section-basic">
            <legend>Basic Details</legend>

            <div class="form-row">
                <div class="input-group">
                    <label for="first_name">First Name:</label>
                    <input type="text" id="first_name" name="first_name">
                    <span id="error-first_name" class="error-text"></span>
                </div>
                <div class="input-group">
                    <label for="last_name">Last Name:</label>
                    <input type="text" id="last_name" name="last_name">
                    <span id="error-last_name" class="error-text"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="input-group">
                    <label for="designation">Designation:</label>
                    <input type="text" id="designation" name="designation">
                    <span id="error-designation" class="error-text"></span>
                </div>
                <div class="input-group">
                    <label for="email">Email:</label>
                    <input type="email" id="email" name="email">
                    <span id="error-email" class="error-text"></span>
                </div>
                <div class="input-group">
                    <label for="phone_number">Phone Number:</label>
                    <input type="text" id="phone_number" name="phone_number">
                    <span id="error-phone_number" class="error-text"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="input-group">
                    <label for="address_1">Address Line 1:</label>
                    <input type="text" id="address_1" name="address_1">
                    <span id="error-address_1" class="error-text"></span>
                </div>
                <div class="input-group">
                    <label for="address_2">Address Line 2:</label>
                    <input type="text" id="address_2" name="address_2">
                    <span id="error-address_2" class="error-text"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="input-group">
                    <label for="city">City:</label>
                    <input type="text" id="city" name="city">
                    <span id="error-city" class="error-text"></span>
                </div>
                <div class="input-group">
                    <label for="state">State:</label>
                    <select name="state" id="state">
                        <option value="" disabled selected>Select State</option>
                        <option value="AP">Andhra Pradesh</option>
                        <option value="MH">Maharashtra</option>
                        <option value="DL">Delhi</option>
                        <option value="GJ">Gujarat</option>
                    </select>
                    <span id="error-state" class="error-text"></span>
                </div>
                <div class="input-group">
                    <label for="zip_code">Zip Code:</label>
                    <input type="text" id="zip_code" name="zip_code">
                    <span id="error-zip_code" class="error-text"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="input-group">
                    <label>Gender:</label>
                    <div>
                        <input type="radio" name="gender" id="male" value="male">
                        <label for="male">Male</label>
                        <input type="radio" name="gender" id="female" value="female">
                        <label for="female">Female</label>
                    </div>
                    <span id="error-gender" class="error-text"></span>
                </div>
                <div class="input-group">
                    <label for="relationship_status">Relationship Status:</label>
                    <select id="relationship_status" name="relationship_status">
                        <option value="" disabled selected>Select Status</option>
                        <option value="single">Single</option>
                        <option value="married">Married</option>
                        <option value="divorced">Divorced</option>
                    </select>
                    <span id="error-relationship_status" class="error-text"></span>
                </div>
                <div class="input-group">
                    <label for="dob">Date of Birth:</label>
                    <input type="date" id="dob" name="dob">
                    <span id="error-dob" class="error-text"></span>
                </div>
            </div>
        </fieldset>

        <fieldset>
            <legend>Education Details</legend>
            <table id="education-info">
                <thead>
                    <tr>
                        <th>Sr. No</th>
                        <th>Course</th>
                        <th>Passing Year</th>
                        <th>Uni/Board</th>
                        <th>Result</th>
                    </tr>
                </thead>
                <tbody id="education-body">
                    <tr>
                        <td>1</td>
                        <td><input type="text" name="degree1"></td>
                        <td><input type="text" name="year_of_passing1"></td>
                        <td><input type="text" name="institution1"></td>
                        <td><input type="text" name="percentage1"></td>
                    </tr>
                    <tr>
                        <td>2</td>
                        <td><input type="text" name="degree2"></td>
                        <td><input type="text" name="year_of_passing2"></td>
                        <td><input type="text" name="institution2"></td>
                        <td><input type="text" name="percentage2"></td>
                    </tr>
                    <tr>
                        <td>3</td>
                        <td><input type="text" name="degree3"></td>
                        <td><input type="text" name="year_of_passing3"></td>
                        <td><input type="text" name="institution3"></td>
                        <td><input type="text" name="percentage3"></td>
                    </tr>
                </tbody>
            </table>
            <input type="button" value="Add Row" id="btn-add-edu">
            <input type="button" value="Remove Last Row" id="btn-remove-edu">
        </fieldset>

        <fieldset>
            <legend>Work Experience</legend>
            <table id="work-info">
                <thead>
                    <tr>
                        <th>Sr. No</th>
                        <th>Company Name</th>
                        <th>Designation</th>
                        <th>From Date</th>
                        <th>To Date</th>
                        <th>Annual Package</th>
                        <th>Reason to Leave</th>
                    </tr>
                </thead>
                <tbody id="workExp-body">
                    <tr>
                        <td>1</td>
                        <td><input type="text" name="company_name1"></td>
                        <td><input type="text" name="job_title1"></td>
                        <td><input type="date" name="start_date1"></td>
                        <td><input type="date" name="end_date1"></td>
                        <td><input type="text" name="salary1"></td>
                        <td><input type="text" name="description1"></td>
                    </tr>
                </tbody>
            </table>
            <input type="button" value="Add Row" id="btn-add-work">
            <input type="button" value="Remove Last Row" id="btn-remove-work">
        </fieldset>
    

     <div id="skills">
        
        <fieldset>
            <legend>Languages You Know..</legend>
            <table>
                <tbody id="lang-body">
         
                </tbody>
            </table>
        </fieldset>

        <fieldset>
            <legend>Technologies Known</legend>
            <table>
                <tbody id="tech-body">
                    
                </tbody>
            </table>
        </fieldset>

    </div>
<fieldset>
            <legend>Preferences & Misc</legend>
            <div class="form-row">
                <div class="input-group">
                    <label for="lp1">Location Priority 1:</label>
                    <select name="lp1" id="lp1">
                        <option value="" disabled selected>Select Location</option>
                        <option value="l1">Location 1</option>
                        <option value="l2">Location 2</option>
                        <option value="l3">Location 3</option>
                    </select>
                    <span id="error-lp1" class="error-text"></span>
                </div>
                <div class="input-group">
                    <label for="lp2">Location Priority 2:</label>
                    <select name="lp2" id="lp2">
                        <option value="" disabled selected>Select Location</option>
                        <option value="l1">Location 1</option>
                        <option value="l2">Location 2</option>
                        <option value="l3">Location 3</option>
                    </select>
                    <span id="error-lp2" class="error-text"></span>
                </div>
                <div class="input-group">
                    <label for="lp3">Location Priority 3:</label>
                    <select name="lp3" id="lp3">
                        <option value="" disabled selected>Select Location</option>
                        <option value="l1">Location 1</option>
                        <option value="l2">Location 2</option>
                        <option value="l3">Location 3</option>
                    </select>
                    <span id="error-lp3" class="error-text"></span>
                </div>
            </div>

            <div class="form-row">
                <div class="input-group">
                    <label for="notice_period_days">Notice Period(Days):</label>
                    <input type="text" name="notice_period_days" id="notice_period_days">
                    <span id="error-notice_period_days" class="error-text"></span>
                </div>
                <div class="input-group">
                    <label for="expected_salary">Expected Salary:</label>
                    <input type="text" name="expected_ctc" id="expected_salary">
                    <span id="error-expected_salary" class="error-text"></span>
                </div>
                <div class="input-group">
                    <label for="current_ctc">Current CTC:</label>
                    <input type="text" name="current_ctc" id="current_ctc">
                    <span id="error-current_ctc" class="error-text"></span>
                </div>
                <div class="input-group">
                    <label for="departments">Department:</label>
                    <select name="department" id="department">
                        <option value="" disabled selected>Select Department</option>
                        <option value="design">Design</option>
                        <option value="development">Development</option>
                        <option value="business">Business</option>
                    </select>
                    <span id="error-department" class="error-text"></span>
                </div>
            </div>
        </fieldset>
        <div class="btn-group">
            <input type="reset" value="Reset Form">
            <input type="submit" value="Submit Application">
            <input type="button" id="btn-validate-basic" value="Check Form Validity">
        </div>

    </form>

    <script src="/js/script.js"></script>
</body>

</html>